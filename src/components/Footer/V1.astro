---
import scripts_json from '@/data/site/scripts.json';
import settings from '@/data/site/settings.json';
const { site_name, legal_entity, brand } = settings;
import { FOOTER_INFO } from '@/const'
import { getEnabledLegalDocuments } from '@/js/utils/legalDocuments';
const url = `https://alexsab.ru?utm_source=client&utm_medium=${brand}&utm_compaing=${scripts_json.site}`;
const legalDocuments = getEnabledLegalDocuments(settings.legal);
---

<footer class="bg-black text-white py-8" x-data="footer">
	<div class="container">
		<div class="flex justify-center">
			<a
				href="#"
				class="disclamer_switch switch text-white underline transition hover:no-underline"
				@click.prevent="onClick"
				>Подробные условия акций</a
			>
		</div>
		<div
			class="disclaimer text-xs"
			x-show="showDisclaimer"
		>
			<noindex>
				<p class="my-10">
					<Fragment set:html={FOOTER_INFO} />
				</p>
			</noindex>
		</div>
		<div class="relative flex flex-col sm:flex-row justify-between pt-10">
			<div class="mb-4">
				<p>© 2024 {legal_entity}</p>
				{legalDocuments.length > 0 && (
					<div class="flex gap-x-4 gap-y-1 flex-wrap mt-3 text-sm opacity-80">
						{legalDocuments.map(document => (
							<a href={document.href} class="underline transition hover:no-underline">{document.label}</a>
						))}
					</div>
				)}
			</div>
			<p class="relative bottom-0 right-0 text-sm opacity-70">Разработка <a href={url} target="_blank">alexsab.ru</a></p>
		</div>
	</div>
</footer>
