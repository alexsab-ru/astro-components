---
type SectionImage = { url: string; title?: string; description?: string };

interface Props {
  images: SectionImage[];
  gallery?: string;
}

const { images, gallery = 'gallery' } = Astro.props;

type GridItem = {
  image: SectionImage;
  colSpan: number;
  rowSpan?: number;
  stretch?: boolean;
  contain?: boolean;
};

// Маппинг colspan → класс (явные строки для Tailwind)
const colSpanClass: Record<number, string> = {
  4:  'col-span-4',
  5:  'col-span-5',
  6:  'col-span-6',
  7:  'col-span-7',
  8:  'col-span-8',
  12: 'col-span-12',
};

// Паттерн для 6 картинок: ряд1 1/3+2/3, ряд2 2/3+1/3, ряд3 1/2+1/2
const sixBlock = (imgs: SectionImage[]): GridItem[] => [
  { image: imgs[0], colSpan: 4, stretch: true }, // 1/3 — растягивается под 2/3
  { image: imgs[1], colSpan: 8 },                // 2/3 — задаёт высоту ряда
  { image: imgs[2], colSpan: 8 },                // 2/3 — задаёт высоту ряда
  { image: imgs[3], colSpan: 4, stretch: true }, // 1/3 — растягивается под 2/3
  { image: imgs[4], colSpan: 6 },
  { image: imgs[5], colSpan: 6 },
];

// Специфичные паттерны для 1-6 картинок
const specificBlock = (imgs: SectionImage[]): GridItem[] => {
  const n = imgs.length;
  if (n === 1) return [
    { image: imgs[0], colSpan: 12, contain: true },
  ];
  if (n === 2) return [
    { image: imgs[0], colSpan: 6 },
    { image: imgs[1], colSpan: 6 },
  ];
  if (n === 3) return [
    { image: imgs[0], colSpan: 6 },
    { image: imgs[1], colSpan: 6 },
    { image: imgs[2], colSpan: 12 },
  ];
  if (n === 4) return [
    { image: imgs[0], colSpan: 8 },                // 2/3 — задаёт высоту ряда
    { image: imgs[1], colSpan: 4, stretch: true }, // 1/3 — растягивается
    { image: imgs[2], colSpan: 4, stretch: true }, // 1/3 — растягивается
    { image: imgs[3], colSpan: 8 },                // 2/3 — задаёт высоту ряда
  ];
  if (n === 5) return [
    // Большая слева row-span-2, справа две, снизу две по 1/2
    { image: imgs[0], colSpan: 7, rowSpan: 2 },
    { image: imgs[1], colSpan: 5 },
    { image: imgs[2], colSpan: 5 },
    { image: imgs[3], colSpan: 6 },
    { image: imgs[4], colSpan: 6 },
  ];
  return sixBlock(imgs);
};

// Разбиваем массив на блоки:
// — если осталось ≤ 6 → специфичный паттерн
// — если следующий остаток после 6 был бы равен 1 → берём 7 (6-паттерн + 1 полный)
// — иначе → берём 6
const blocks: GridItem[][] = [];
let remaining = [...images];

while (remaining.length > 0) {
  const n = remaining.length;
  if (n <= 6) {
    blocks.push(specificBlock(remaining));
    remaining = [];
  } else if (n - 6 === 1) {
    blocks.push(sixBlock(remaining.slice(0, 6)));
    blocks.push([{ image: remaining[6], colSpan: 12 }]);
    remaining = remaining.slice(7);
  } else {
    blocks.push(sixBlock(remaining.slice(0, 6)));
    remaining = remaining.slice(6);
  }
}
---

{blocks.map((block) => (
  <div class="grid grid-cols-12 gap-1 sm:gap-2 md:gap-3 xl:gap-4 mb-4">
    {block.map((item) => (
      <a
        href={item.image.url}
        class:list={[
          'glightbox relative block overflow-hidden rounded-xl cursor-pointer',
          colSpanClass[item.colSpan],
          item.rowSpan === 2 ? 'row-span-2' : item.stretch ? 'self-stretch' : 'aspect-video',
        ]}
        data-title={item.image.title}
        data-description={item.image.description?.replace(/<[^>]*>/g, '').trim()}
        data-gallery={gallery}
      >
        <img
          src={item.image.url}
          alt={item.image.title ?? ''}
          class:list={['absolute inset-0 w-full h-full', item.contain ? 'object-contain' : 'object-cover']}
        />
      </a>
    ))}
  </div>
))}
