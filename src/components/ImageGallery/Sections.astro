---
import Grid from './Grid.astro';
import SimpleGrid from './SimpleGrid.astro';

type SectionImage = { url: string; title?: string; description?: string };

interface Props {
  sections: {
    id: string;
    title: string;
    images?: SectionImage[];
  }[];
  variant?: 'grid' | 'simple';
}

const { sections, variant = 'grid' } = Astro.props;

const filteredSections = sections.filter((section) => section.images?.length);
---

{filteredSections.map((section) => (
  <section class="">
    <h2 class="text-2xl sm:text-4xl font-bold mb-6">{section.title}</h2>
    {variant === 'simple' ? (
      <SimpleGrid
        images={section.images as SectionImage[]}
        gallery={`gallery-${section.id}`}
        title={section.title}
      />
    ) : (
      <Grid
        images={section.images as SectionImage[]}
        gallery={`gallery-${section.id}`}
      />
    )}
  </section>
))}
