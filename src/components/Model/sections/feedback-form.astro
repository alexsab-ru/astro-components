---
import FeedbackForm from '@/components/FeedbackForm/FeedbackForm.astro';

type TFeedbackForm = {
	title?: string;
	subtitle?: string;
	description?: string;
	imageUrl?: string;
	dataFormName?: string;
	showModelSelect?: boolean;
}

interface Props {
	feedbackForm?: TFeedbackForm;
}

const { feedbackForm = {} } = Astro.props;
const subtitle = feedbackForm.subtitle ?? feedbackForm.description ?? '';
---

<FeedbackForm
	title={feedbackForm.title}
	subtitle={subtitle}
	imageUrl={feedbackForm.imageUrl}
	dataFormName={feedbackForm.dataFormName}
	showModelSelect={feedbackForm.showModelSelect}
/>
