---
type TImage = {
	url: string;
	title?: string;
	description?: string;
}

type TItem = {
	icon: string;
	text: string;
}

interface Props {
	section: {
		[key: string]: any;
		id?: string;
		type?: string;
		sectionClass?: string;
		content?: Record<string, any>;
		contentOrder?: string[];
		items?: TItem[];
		subtitle?: string;
		title?: string;
		text?: string;
		more?: string;
		images?: TImage[];
		button?: string;
		alternatingMedia?: {
			name?: string;
			title?: string;
			descr?: string;
			items?: {
				title?: string;
				descr?: string;
				img?: string;
			}[];
		};
		advantages?: {
			name?: string;
			title?: string;
			descr?: string;
			items?: {
				title?: string;
				descr?: string;
			}[];
			img?: string;
		};
		feedbackForm?: {
			title?: string;
			subtitle?: string;
			description?: string;
			imageUrl?: string;
			dataFormName?: string;
			showModelSelect?: boolean;
		};
	}
}
const { section, ...rest } = Astro.props;
const sectionContent = section?.content ?? section ?? {};
const contentOrder = Array.isArray(section?.contentOrder)
	? section.contentOrder
	: Object.keys(sectionContent);

import SubtitleSection from './subtitle.astro';
import TitleSection from './title.astro';
import TextSection from './text.astro';
import MoreSection from './more.astro';
import ItemsSection from './items.astro';
import ImagesSection from './images.astro';
import ButtonSection from './button.astro';
import AlternatingMediaSection from './alternating-media.astro';
import AdvantagesSection from './advantages.astro';
import FeedbackFormSection from './feedback-form.astro';
---

<section class:list={['sm:py-20 py-10 font-light model-section odd:bg-gray-100', section?.sectionClass]} id={section?.id} {...rest}>
	<div class="container">
		{contentOrder.map((key) => {
			const value = sectionContent[key];

			switch (key) {
				case 'subtitle':
					return <SubtitleSection value={value} />;
				case 'suptitle':
					return <SubtitleSection value={value} />;
				case 'title':
					return <TitleSection value={value} />;
				case 'text':
					return <TextSection value={value} />;
				case 'more':
					return <MoreSection value={value} />;
				case 'items':
					return <ItemsSection items={value} />;
				case 'images':
					return <ImagesSection images={value} sectionId={section?.id} title={sectionContent?.title} />;
				case 'button':
					return <ButtonSection value={value} />;
				case 'alternatingMedia':
					return <AlternatingMediaSection section={value} />;
				case 'advantages':
					return <AdvantagesSection section={value} />;
				case 'feedbackForm':
					return <FeedbackFormSection feedbackForm={value} />;
				default:
					return null;
			}
		})}
	</div>
</section>
