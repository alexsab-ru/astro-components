---
interface Props {
	models?: any[];
	title?: string;
	classes?: string;
	getModelPath?: (model: any) => string;
}
import ModelItem from './Item.astro';
import { groupArrayByKey } from '@/js/utils/groupArrayByKey';
import { isModelVisible } from '@/js/utils/modelVisibility';
import { setPrefixModelUrl } from '@/js/utils/helpers';
import { IS_MODEL_PREFIX_URL } from '@/const';

import modelsData from '@/data/models.json';
const { models: modelsArr } = modelsData;
const defaultGetModelPath = (model: any) => `/models/${setPrefixModelUrl(model, IS_MODEL_PREFIX_URL)}/`;
const {models = modelsArr, title = 'Модельный ряд', classes, getModelPath = defaultGetModelPath, ...rest} = Astro.props;
const filteredModels = models.filter(isModelVisible);
const groupModelsByBrand = groupArrayByKey(filteredModels, 'mark_id');
const brandCount = Object.keys(groupModelsByBrand).length;
const multipleBrands = brandCount > 1;
// Если title есть (h2), то бренды — h3, иначе бренды — h2
const BrandTag = title ? 'h3' : 'h2';
// Если несколько брендов — карточка h3, если один — h2
const cardHeadingLevel: 'h2' | 'h3' = (multipleBrands || !!title) ? 'h3' : 'h2';
---

{
	brandCount > 0 && (
		<section class={`models py-10 sm:py-20 ${classes}`} {...rest}>
			<div class="container">
				{title && ( <h2 class="text-center mobile-title-size sm:text-4xl mb-8 sm:mb-14">{title}</h2>)}
				{Object.keys(groupModelsByBrand).map(key => (
					<>

						{multipleBrands && (<BrandTag class="text-2xl md:text-3xl lg:text-5xl mb-5 lg:mb-8">{key}</BrandTag>)}

						<div class={`flex flex-wrap mb-10 lg:mb-20 last:mb-0 lg:gap-5 text-xs 2xl:text-base justify-between ${multipleBrands ? 'lg:justify-start' : 'lg:justify-center'}`}>
							{groupModelsByBrand[key].map((model: any) => (

								<ModelItem model={model} modelPath={getModelPath(model)} headingLevel={cardHeadingLevel} />
								
							))}
						</div>

					</>
				))}
			</div>
		</section>
	)
}
