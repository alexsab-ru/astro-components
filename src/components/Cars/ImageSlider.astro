---
const { data = {} } = Astro.props;
import '@/components/Banner/banner.css';
import './image-slider.css';

const imageSets = data.imageSets && data.imageSets.length
	? data.imageSets
	: (data.images || []).map((img:string) => ({
		full: img,
		large: img,
		medium: img,
		small: img,
		thumb: 'https://cdn.alexsab.ru/loaders/simple-loading-gray.svg',
	}));
---

<div class="swiper car-image-slider w-full mb-2.5 bg-gray-50 h-[52.6vw] sm:h-auto sm:aspect-video">
	<div class="swiper-wrapper">
			{
				imageSets.map((img:any) => (
					<div class="swiper-slide w-fit! sm:w-full! lazy">
						<a 
							href={img.full} 
							class="inline-block sm:block cursor-zoom-in h-full w-auto sm:w-full select-none glightbox"
							data-gallery={data.vin_hidden}
						>
							<img src={img.thumb} data-src={img.large} class="w-auto sm:mx-auto h-full object-cover select-none" alt={data.folder_id} height="405" loading="lazy" />
							<div class="swiper-lazy-preloader"></div>
						</a>
					</div>
				))
			}
	</div>
	<div class="swiper-button-prev car-image-slider-prev hidden! sm:flex!"></div>
	<div class="swiper-button-next car-image-slider-next hidden! sm:flex!"></div>
</div>
<div class="swiper car-thumb-slider hidden! sm:block! h-[130px]">
	<div class="swiper-wrapper">
		{
			imageSets.map((img:any) => (
				<div class="swiper-slide select-none min-w-[200px] flex justify-start! items-center" data-thumb-lazy>
					<img src={img.thumb} data-src={img.small} class="select-none h-full w-auto" alt={data.folder_id} height="130" loading="lazy" />
					<div class="swiper-lazy-preloader"></div>
				</div>
			))
		}
	</div>
</div>

<script>
	import './slider';
</script>
