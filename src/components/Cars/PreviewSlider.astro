---
interface Props {
	car: any;
	url: string
}
const { car= {}, url } = Astro.props;
import settings from '@/data/site/settings.json';
if(settings.brand === 'Livan') { settings.brand = 'ЛИВЭН (LIVAN)'; }
const { brand, legal_city_where } = settings;
import './cars.css'

const previewImages = car.data.imageSets && car.data.imageSets.length
	? car.data.imageSets.map((img:any) => ({
		src: img.medium,
		placeholder: img.thumb,
	}))
	: (car.data.thumbs || []).map((img:string) => ({
		src: img,
		placeholder: 'https://cdn.alexsab.ru/loaders/simple-loading-gray.svg',
	}));
---
<div class="w-full relative mb-2.5">
	<div class="flex-full lg:flex-none relative flex group" x-data="usedPreviewGallery">
		{
			previewImages.length > 0 ? (
			<Fragment><div class="overflow-x-auto flex gap-[5px] lg:gap-0 snap-x snap-mandatory w-full scroll-smooth no-scrollbar" x-ref="wrapper">
			{
				previewImages.map((img:any, idx:number) => (
					idx < 5 && (
						<a href={url} class="lazy lazy-stretch relative snap-always snap-start shrink-0 w-full aspect-4/3 block mb-0!" data-slide={idx}>
							<img class="w-full h-full object-cover object-center" src={img.placeholder} data-src={img.src} alt={`Купить ${ car.data.mark_id } ${car.data?.folder_id} ${car.data?.color} ${car.data?.modification_id} от ${car.data?.priceWithDiscount} ₽. в ${legal_city_where}`} width="359" />
							{
								idx === 4 && car.data.images.length > 5 && (
								<div class="absolute inset-0 bg-black/60 text-center flex items-center justify-center z-10 text-white text-sm sm:text-base"> Еще <br /> { car.data.images.length - 5} фото</div>
								)
							}
						</a>
					)
				))
			}
			</div><div class="absolute hover-unavail:hidden opacity-0 group-hover:opacity-100 flex justify-between top-0 left-0 w-full h-full gap-1 pb-1.5 z-20" x-on:mouseleave="showSlideAt(0)">
			{
				previewImages.map((img:any, idx:number) => (
					idx < 5 && (
					<a href={url} class="w-full flex items-end h-full" x-on:mouseover={`showSlideAt(${idx})`}>
						<div class="w-full h-[3px] bg-black/80 aria-selected:bg-accent-500" x-bind:aria-selected={`activeIndex == ${idx}`} aria-selected={idx === 0 ? true : false}></div>
					</a>
					)
				))
			}
			</div></Fragment>
			) : (
			<a href={url} class="lazy lazy-stretch relative snap-always snap-start shrink-0 w-full aspect-4/3 mb-0!" title="Подробнее">
				<img src="https://cdn.alexsab.ru/loaders/simple-loading-gray.svg" data-src={car.data.image} class="relative top-1/2 -translate-y-1/2 w-full h-auto object-contain" alt={`Купить ${ car.data.mark_id } ${car.data?.folder_id} ${car.data?.color} ${car.data?.modification_id} от ${car.data?.priceWithDiscount} ₽. в ${legal_city_where}`} width="359" />
			</a>
			)
		}
	</div>
</div>
