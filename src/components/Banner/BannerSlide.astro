---
import type { TBanner } from './types';
interface Props {
	banner: TBanner;
	index?: number;
	onlyView?: boolean;
	onlyModal?: boolean;
}
const {banner, index, onlyView, onlyModal} = Astro.props;
import Button from '../Button/Button.astro';
import Badge from './Badge.astro';
import BannerTitle from './Title.astro';
import BannerDescription from './Description.astro';
import BannerVideo from './Video.astro';
import BannerImage from './Image.astro';

import settings from '@/data/settings.json';
const { is_header_transparent, header_top_line } = settings;

const containerClasses = is_header_transparent && header_top_line
	? 'pt-[117px] md:pt-[141px] lg:pt-[190px]'
	: is_header_transparent
	? 'pt-[80px] md:pt-[100px] lg:pt-[149px]'
	: 'pt-5 sm:pt-10 lg:py-10';

// Определяем цвет кнопки с fallback на белый
const btnColor = banner?.btnColor ? banner?.btnColor : 'white';

const hasVideoSource = Boolean(
	banner?.videoUrl ||
	banner?.mobileVideoUrl ||
	banner?.video?.desktop ||
	banner?.video?.tablet ||
	banner?.video?.mobile
);
const isVideo = hasVideoSource;

// Единый URL для всего баннера: bannerUrl → url → btnUrl (приоритет от специфичного к общему)
const resolvedUrl = onlyModal && (banner?.bannerUrl || banner?.url || banner?.btnUrl)
	? '#common-modal'
	: banner?.bannerUrl || banner?.url || banner?.btnUrl;

// URL для кнопки: btnUrl → url
const resolvedBtnUrl = onlyModal && (banner?.btnUrl || banner?.url)
	? '#common-modal'
	: banner?.btnUrl || banner?.url;

const isModalHref = (href?: string) => !!href && href.toLowerCase().includes('#common-modal');
const isPopupBannerLink = isModalHref(resolvedUrl);
const buttonView = isModalHref(resolvedBtnUrl) ? 'popup-link' : 'link';
const hasBannerUrl = !!resolvedUrl;
const stripHtml = (value?: string) => (value ? value.replace(/<[^>]*>/g, '').trim() : '');
const resolvedDataTitle = banner?.dataTitle || stripHtml(banner?.title) || 'Обратная связь';
const resolvedDataFormName = banner?.dataFormName || `${resolvedDataTitle}. Баннер`;

const BannerType = isVideo ? BannerVideo : BannerImage;

// Атрибуты прозрачного оверлея-ссылки поверх всего баннера
const linkAttrs = hasBannerUrl ? {
	href: resolvedUrl as string,
	class: `absolute inset-0 h-full w-full z-10 block ${isPopupBannerLink ? 'popup-link' : ''}`,
	'data-title': resolvedDataTitle,
	'data-form_name': resolvedDataFormName,
	...(banner?.target && !isPopupBannerLink ? {target: banner.target} : {}),
} : null;
---

<div class={`swiper-slide banner-slide ${banner?.gradient === false ? '' : 'gradient'}`} data-swiper-autoplay={banner?.autoplay ? banner.autoplay : 5000}>
	{/* Медиа первым в DOM — естественно под текстом без z-index */}
	<BannerType banner={banner} {...(!isVideo ? { index } : {})} />

	{/* Текст: relative без z-index — выше картинки по DOM-порядку */}
	<div class={`h-full relative px-5 sm:px-10 md:px-20 pb-5 banner-slide-container ${containerClasses}`}>
		<div class="h-full flex flex-col justify-between">
			<div class="">
				{ banner?.title && ( <div class="relative z-1"><BannerTitle title={banner.title} /></div> ) }
				{ banner?.descr && ( <div class="relative z-1"><BannerDescription description={banner.descr} /></div> ) }
				{
					(!onlyView || onlyModal) && banner?.btn && (
						<div data-swiper-parallax="-55%" class="relative z-20 inline-block mt-8 sm:mt-10">
							<Button
								classes={`btn inline-block py-2! sm:py-3 text-sm sm:text-base ${btnColor}`}
								view={buttonView}
								url={resolvedBtnUrl}
								title={banner?.btn}
								dataTitle={resolvedDataTitle}
								dataFormName={resolvedDataFormName}
							/>
						</div>
					)
				}
			</div>
			{
				(banner?.badge || banner?.disclaimer) && (
					<div class="relative z-1">
						{
							banner?.badge && (
								<Badge
									autoname={banner.badge?.autoname}
									title={banner.badge?.title}
									descr={banner.badge?.descr}
									image={banner.badge?.image}
									position={banner.badge?.position}
									colorText={banner.badge?.colorText}
									bg={banner.badge?.bg}
								/>
							)
						}
						{
							banner?.disclaimer && (
								<div class="mt-4 text-xs sm:text-sm text-white/90 relative z-10">
									<Fragment set:html={banner.disclaimer} />
								</div>
							)
						}
					</div>
				)
			}
		</div>
	</div>

	{/* Оверлей-ссылка z-10: выше текста (z-auto), но ниже кнопки (z-20) */}
	{ hasBannerUrl && (!onlyView || onlyModal) && <a {...linkAttrs} /> }
</div>
