---
import { render } from 'astro:content';
import { getSafeEntry } from '@/js/utils/safeContent';

interface Props {
  mdx?: string;
  text?: string;
  noPadding?: boolean;
  sectionPaddingBlock?: boolean;
}

const { mdx, text, noPadding = false, sectionPaddingBlock = false } = Astro.props;

// Приоритет у inline-текста; mdx-файл подтягивается только если text пуст.
const hasText = typeof text === 'string' && text.trim().length > 0;

let Content = null;
if (!hasText && mdx) {
  const content = await getSafeEntry('seo', mdx);
  if (content) {
    const result = await render(content);
    Content = result.Content;
  }
}

const showseo = hasText || Content !== null;
---

{ showseo ? (
<section class={`${!sectionPaddingBlock ? 'pt-0!' : ''}`}>
	<div class={`container ${noPadding ? 'px-0!' : ''}`}>
		<div class="seo-content">
			{hasText ? <Fragment set:html={text} /> : <Content />}
		</div>
		<div class="flex justify-center mt-6">
			<a href="javascript:void(0)" class="seo-show-more text-sm opacity-50 transition-opacity hover:opacity-90 leading-none py-3 relative no-underline!">
				<span class="seo-show-more-text">читать полностью</span>
				<span class="seo-show-more-arrow inline-block rotate-90 transition-transform absolute bottom-0 left-1/2 transform -translate-x-1/2 origin-center">&#187;</span>
			</a>
		</div>
	</div>
</section>
) : ('')}
