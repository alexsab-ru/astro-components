---
interface Props {
    bgUrl?: string;
    bgImage?: {
        desktop?: string;
        tablet?: string;
        mobile?: string;
    };
    bgPosition?: {
        desktop?: string;
        tablet?: string;
        mobile?: string;
    };
    title?: string;
    subtitle?: string;
    formName?: string;
    btn?: string;
    showComment?: boolean;
    commentPlaceholder?: string;
}
import settings from '@/data/site/settings.json';
import salons from '@/data/site/salons.json';
import type { ISalon } from '@/types/ISalon';
const { improve_offer_background, agree_label } = settings;
const {
    bgUrl = improve_offer_background,
    bgImage,
    bgPosition,
    title = "Улучшим предложение конкурентов!", 
    subtitle = "<p>У Вас уже есть предложение от другого дилера?</p><p>Сделаем лучше!</p><p>Оставьте Ваши контакты и в ближайшее время мы перезвоним!</p>",
    formName = "Улучшим предложение конкурентов",
    btn = "Отправить",
    showComment = true,
    commentPlaceholder = "Напишите предложение конкурента*",
    ...rest
} = Astro.props;
import Button from '@/ui/button/Button.astro';
import Input from '@/ui/input/Input.astro';
import Checkbox from '@/ui/checkbox/Checkbox.astro';
import ChoosingDealerSelect from '@/ui/choosing-dealer-select/ChoosingDealerSelect.astro';
import Textarea from '@/ui/textarea/Textarea.astro';

const defaultBgPosition = 'bottom';
const desktopBg = bgImage?.desktop ?? bgUrl;
const tabletBg = bgImage?.tablet ?? desktopBg;
const mobileBg = bgImage?.mobile ?? tabletBg;
const desktopBgPosition = bgPosition?.desktop ?? defaultBgPosition;
const tabletBgPosition = bgPosition?.tablet ?? desktopBgPosition;
const mobileBgPosition = bgPosition?.mobile ?? tabletBgPosition;

const cssUrl = (url: string) => `url("${url.replace(/"/g, '\\"')}")`;
const callbackStyle = [
    `--callback-bg-mobile: ${cssUrl(mobileBg)}`,
    `--callback-bg-tablet: ${cssUrl(tabletBg)}`,
    `--callback-bg-desktop: ${cssUrl(desktopBg)}`,
    `--callback-bg-position-mobile: ${mobileBgPosition}`,
    `--callback-bg-position-tablet: ${tabletBgPosition}`,
    `--callback-bg-position-desktop: ${desktopBgPosition}`,
].join('; ');
---

<section class="callback-bg-responsive text-white py-20 sm:py-24 bg-cover relative z-1 before:content-[''] before:absolute before:inset-0 before:bg-black/60 before:z-[-1] model-section" style={callbackStyle} {...rest}>
    <div class="section-grid">
        <div class="w-wull xl:w-1/2 text-base sm:text-xl leading-normal!">
            {title && (<h2 class="text-left text-xl sm:text-5xl mb-4 before:hidden ml-0 mr-0">{title}</h2>)}
            {subtitle !== '' && <Fragment set:html={subtitle} />}
            <form class="mt-14 sm:max-w-md text-base">
                <input type="hidden" name="form" value={formName}>

                <input
                    type="email"
                    tabindex="-1"
                    name="email"
                    class="h-0 opacity-0 absolute -z-100"
                    placeholder="mail@example.com"
                />

                <div class="flex flex-col gap-y-4 mb-5">

                    <Input
                        type="text"
                        name="name"
                        classes="border-gray-100"
                        placeholder="Имя (необязательное)"
                    />

                    <Input
                        type="tel"
                        name="phone"
                        classes="border-gray-100"
                        placeholder="+7 (999) 999-99-99*"
                        required
                        errorClasses="text-red-500 text-xs"
                    />

                    <ChoosingDealerSelect required={true} salons={salons} />

                    {showComment && (
                        <Textarea classes="border-gray-100 resize-none min-h-[100px] overflow-y-auto" name="comment" required placeholder={commentPlaceholder} minlength="10" />
                    )}

                    <input
                        type="checkbox"
                        name="subscribe"
                        class="absolute w-0 h-0 opacity-0 invisible"
                    />

                    <Button view="form-button" classes="w-full" title={btn} />

                </div>

                <Checkbox
                    name="agree"
                    label={agree_label}
                    color="white"
                    required
                    errorClasses="text-red-500 text-xs w-full"
                    errorText="Чтобы продолжить, установите флажок"
                />

            </form>
        </div>
    </div>
</section>

<style>
    .callback-bg-responsive {
        background-image: var(--callback-bg-mobile);
        background-position: var(--callback-bg-position-mobile, bottom);
    }

    @media (min-width: 768px) {
        .callback-bg-responsive {
            background-image: var(--callback-bg-tablet);
            background-position: var(--callback-bg-position-tablet, bottom);
        }
    }

    @media (min-width: 1024px) {
        .callback-bg-responsive {
            background-image: var(--callback-bg-desktop);
            background-position: var(--callback-bg-position-desktop, bottom);
        }
    }
</style>
