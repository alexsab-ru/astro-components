---
// Блок сетки автомобилей в наличии (вынесен из роута models/[...slug]).
import CarsItem from '@/blocks/cars/CarsItem.astro';

interface Props {
	cars?: any[];
	title?: string;
}
const { cars = [], title } = Astro.props;
---
{
	!!cars.length && (
		<section class="odd:bg-gray-100">
			<div class="section-grid">
				{title && (
					<h2 class="text-center mobile-title-size sm:text-4xl mb-8 sm:mb-14">
						<Fragment set:html={title} />
					</h2>
				)}
				<div class="full-bleed flex flex-wrap justify-center gap-3 sm:gap-5 mt-5 car-list px-2 sm:px-4">
					{cars.map((car) => (
						<CarsItem car={car} />
					))}
				</div>
			</div>
		</section>
	)
}
