---
import type { TBanner } from './types';
interface Props {
	banner: TBanner;
	index?: number;
	onlyView?: boolean;
	onlyModal?: boolean;
}
const {banner, index, onlyView, onlyModal} = Astro.props;
import Button from '@/ui/button/Button.astro';
import Badge from './BannerBadge.astro';
import BannerTitle from './BannerTitle.astro';
import BannerDescription from './BannerDescription.astro';
import BannerVideo from './BannerVideo.astro';
import BannerImage from './BannerImage.astro';
import { resolveBannerLink } from './link.js';

import settings from '@/data/site/settings.json';
import scripts from '@/data/site/scripts.json';
import { isHeaderTransparentEnabled } from '@/js/utils/features';
const { header_top_line } = settings;
const is_header_transparent = isHeaderTransparentEnabled(settings);

const containerClasses = is_header_transparent && header_top_line
	? 'pt-[117px] md:pt-[141px] lg:pt-[190px]'
	: is_header_transparent
	? 'pt-[80px] md:pt-[100px] lg:pt-[149px]'
	: 'pt-5 sm:pt-10 lg:py-10';

const btnColor = banner?.btnColor ? banner?.btnColor : 'white';
const isVideo = Boolean(
	banner?.video?.desktop ||
	banner?.video?.tablet ||
	banner?.video?.mobile
);
const bannerLink = resolveBannerLink(
	onlyModal && banner?.url ? { ...banner, url: '#common-modal' } : banner,
	{ siteOrigin: scripts.site }
);
const popupLinkClass = bannerLink?.isPopup ? 'popup-link' : '';
const stripHtml = (value?: string) => (value ? value.replace(/<[^>]*>/g, '').trim() : '');
const dataTitle = banner?.dataTitle || stripHtml(banner?.title) || 'Обратная связь';
const dataFormName = banner?.dataFormName || `${dataTitle}. Баннер`;
const BannerType = isVideo ? BannerVideo : BannerImage;
const badgePosition = typeof banner?.badge === 'object' && !Array.isArray(banner.badge)
	? banner.badge?.position
	: 'center';
const badgeBlockPositionClass = badgePosition === 'right'
	? 'items-end'
	: badgePosition === 'left'
	? 'items-start'
	: 'items-center';

const linkAttrs = bannerLink ? {
	href: bannerLink.href,
	class: `absolute inset-0 h-full w-full z-10 block ${popupLinkClass}`,
	'aria-label': dataTitle,
	'data-title': dataTitle,
	'data-form_name': dataFormName,
	...(bannerLink.target ? { target: bannerLink.target } : {}),
	...(bannerLink.rel ? { rel: bannerLink.rel } : {}),
} : null;
---

<div class={`swiper-slide banner-slide ${banner?.gradient === false ? '' : 'gradient'}`} data-swiper-autoplay={banner?.autoplay ? banner.autoplay : 5000}>
	<BannerType banner={banner} {...(!isVideo ? { index } : {})} />

	<div class={`h-full relative z-20 pointer-events-none px-5 sm:px-10 md:px-20 pb-5 banner-slide-container ${containerClasses}`}>
		<div class="h-full flex flex-col justify-between">
			<div class="">
				{ banner?.title && ( <BannerTitle title={banner.title} /> ) }
				{ banner?.description && ( <BannerDescription description={banner.description} /> ) }
				{
					(!onlyView || onlyModal) && banner?.btn && bannerLink && (
						<div data-swiper-parallax="-55%" class="pointer-events-auto">
							<Button
								classes={`${popupLinkClass} py-2! sm:py-3 text-sm sm:text-base mt-8 sm:mt-10 ${btnColor}`}
								view="link"
								url={bannerLink.href}
								title={banner?.btn}
								dataTitle={dataTitle}
								dataFormName={dataFormName}
								{...(bannerLink.target ? { target: bannerLink.target } : {})}
								{...(bannerLink.rel ? { rel: bannerLink.rel } : {})}
							/>
						</div>
					)
				}
			</div>
			{
				(banner?.badge || banner?.disclaimer) && (
					<div class="w-full">
						{
							banner?.badge && (
								<div class={`flex w-full flex-col ${badgeBlockPositionClass}`}>
									<Badge
										autoname={banner.badge?.autoname}
										title={banner.badge?.title}
										description={banner.badge?.description}
										image={banner.badge?.image}
										position={banner.badge?.position}
										colorText={banner.badge?.colorText}
										bg={banner.badge?.bg}
									/>
								</div>
							)
						}
						{
							banner?.disclaimer && (
								<div class="mt-3 text-xs sm:text-sm text-white/90">
									<Fragment set:html={banner.disclaimer} />
								</div>
							)
						}
					</div>
				)
			}
		</div>
	</div>

	{ bannerLink && (!onlyView || onlyModal) && <a {...linkAttrs} /> }
</div>
