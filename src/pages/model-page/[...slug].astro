---
import { isRouteDisabled } from '@/js/utils/siteRoutes';
import Layout from '@/layouts/Layout.astro';
import Banner from '@/components/Banner/Banner.astro';
import bannersData from '@/data/banners.json';
import type { TBanner } from '@/components/Banner/types';
import PageH1 from '@/components/PageH1/Index.astro';
import modelsData from '@/data/models.json';
import settings from '@/data/settings.json';
import FeedbackForm from '@/components/FeedbackForm/FeedbackForm.astro';
import Sections from '@/components/ImageGallery/Sections.astro';
import { setPrefixModelUrl } from '@/js/utils/helpers';
import { IS_MODEL_PREFIX_URL } from '@/const';
import salonsData from '@/data/salons.json';
import type { ISalon } from '@/types/ISalon';

const salons = salonsData.filter((salon: ISalon) => !salon?.type || salon?.type.includes('index'));
const salonsPhone = salons.map((salon: any) => salon.phone).filter(phone => phone).join(', ');

const allSections = import.meta.glob('/src/data/model-sections/**/*.yml', { eager: true });

export async function getStaticPaths() {
  if (isRouteDisabled('/model-page/')) return [];
  return modelsData.models
    .filter((m) => m.show)
    .map((model) => ({
      params: { slug: setPrefixModelUrl(model, IS_MODEL_PREFIX_URL) },
      props: { model },
    }));
}

const { model } = Astro.props;
const { legal_city_where } = settings;
const { name, caption, slogan, homeImg, id, thumb, mark_id } = model;
const modelTitle = caption ?? name ?? '';

const brandFolder = mark_id.toLowerCase();
const sectionsModule = allSections[`/src/data/model-sections/${brandFolder}/${model.id}.yml`] as { default: any[] } | undefined;
const rawSections = sectionsModule?.default ?? [];

const escapeRegex = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
const urlSegment = `/${id.toLowerCase()}/`;
const nameRegex = new RegExp(`(?<![\\w+])${escapeRegex(name)}(?![\\w+])`, 'i');
const isRelated = (banner: TBanner) => {
  if (banner.btnUrl?.toLowerCase().includes(urlSegment)) return true;
  if (banner.bannerUrl?.toLowerCase().includes(urlSegment)) return true;
  return [banner.title, banner.descr, banner.dataTitle].some((f) => (f ? nameRegex.test(f) : false));
};

let relatedSlidesCount = 0;
const relatedBanners: TBanner[] = [];
const otherBanners: TBanner[] = [];

for (const banner of bannersData as TBanner[]) {
  if (isRelated(banner)) {
    relatedSlidesCount += 1;
    relatedBanners.push(banner);
  } else {
    otherBanners.push(banner);
  }
}

const sortedBanners = relatedSlidesCount > 0 ? [...relatedBanners, ...otherBanners] : [];
---

<Layout
  title={`${mark_id} ${modelTitle} – фото ${mark_id} ${modelTitle} в ${legal_city_where}`} 
  description={`${mark_id} ${modelTitle} купить в ${legal_city_where}. Кредит, скидки на все автомобили от розничной цены. Гарантия. Звонить по тел.: ${salonsPhone}`}
  brand={mark_id}
  image={homeImg ?? thumb ?? ''}
  showHeaderMenu={false}
  showFooterLinks={false}
  logoNoLink={true}>
  {relatedSlidesCount > 0 && <Banner banners={sortedBanners} onlyModal={true} />}
  <div class="px-2 md:px-4 mt-6 xl:mt-12">
    <section>
      <PageH1 classes="text-center text-4xl! md:text-6xl!" h1={`${mark_id} ${name}`} />
      {
        slogan && (
          <div class="text-center text-4xl">{`${slogan}`}</div>
        )
      }
    </section>

    <div class="text-center">
      <a
        href="#feedback"
        class="btn inline-block py-3 px-8 text-lg bg-accent-500 text-white rounded-lg transition hover:bg-accent-600"
      >
        Узнать подробности
      </a>
    </div>

    <Sections sections={rawSections} variant="grid" ctaHref="#feedback" ctaText="Узнать подробности" />

    <section id="feedback" class="bg-gray-50">
      <FeedbackForm
        title="Остались вопросы?"
        subtitle="Оставьте заявку и мы свяжемся с вами"
        dataFormName={`Заявка на ${mark_id} ${name}`}
      />
    </section>
  </div>
</Layout>
