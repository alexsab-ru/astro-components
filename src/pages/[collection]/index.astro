---
import { isRouteDisabled, SITE_NOT_FOUND_PATH } from '@/js/utils/siteRoutes';
import type { TCollection } from '@/types/TCollection';
import PageLayout from '@/layouts/PageLayout.astro';
import settings from '@/data/site/settings.json';
const { site_name } = settings;
import PostItem from '@/blocks/post/PostItem.astro';
import { sortingAndFilteringPosts } from '@/js/utils/sortingAndFilteringPosts';
import { getRandomInt } from '@/js/utils/numbers.format';
import SeoText from '@/blocks/seo/Seo.astro';
import { getIndexCollections } from '@/content-config/collections';
import { getSafeCollection } from '@/js/utils/safeContent';

export async function getStaticPaths() {
  return getIndexCollections()
		.filter((c) => !isRouteDisabled(`/${c.name}/`))
		.map((collection) => ({ 
		params: { collection: collection.name },
		props: {
			title: collection.title,
			h1: collection.h1,
			breadcrumb: collection.breadcrumb,
			description: collection.description,
			image: collection.image,
		}
	}));
}

const { collection } = Astro.params;
if (typeof collection === 'string' && isRouteDisabled(`/${collection}/`)) {
	return Astro.rewrite(SITE_NOT_FOUND_PATH);
}
const { title, h1, breadcrumb: collectionBreadcrumb, description, image: seoImage } = Astro.props;
// seo.title уже может содержать «| site_name» — не дублируем суффикс
const metaTitle = title.includes('|') ? title : `${title} | ${site_name}`;
const entries = await getSafeCollection(collection as string);
let posts: TCollection[], image = '';
if (entries && entries.length > 0) {
	posts = sortingAndFilteringPosts(entries);
	if(posts.length > 0){
		image = posts[getRandomInt(0, posts.length)].data.image;
	}
} else {
	// Если массив пустой, можно присвоить image значение по умолчанию или обработать этот случай
	image = ''; // или какая-то другая логика
	posts = [];
}
const breadcrumb = { name: collectionBreadcrumb, href: `/${collection}/` };
---

<PageLayout
	h1={h1}
	title={metaTitle}
	description={`${description}`}
	breadcrumb={[breadcrumb]}
	image={seoImage || image || ''}
	backLink={true}
	noindex={posts.length === 0}
>
	<SeoText mdx={collection} noPadding />
	{
		posts.length > 0 ? (
			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5">
				{ posts.map(post => ( <PostItem post={post} /> )) }
			</div>
		) : (
			<p>Скоро здесь появятся {h1.toLowerCase()} {site_name}.</p>
		)
	}
</PageLayout>
