---
import { isRouteDisabled } from '@/js/utils/siteRoutes';
import Layout from '@/layouts/Layout.astro';
import BlockRenderer from '@/page-builder/BlockRenderer.astro';
const { slug } = Astro.params;
const seoname = 'models-'+slug;

import modelsData from '@/data/site/models.json';
import { isModelVisible } from '@/js/utils/modelVisibility';
import { normalizeModelId } from '@/js/utils/normalizeModelId';
import { getModelBlocks, setPrefixModelUrl } from '@/js/utils/helpers';
import {
  getModelBrandDisplayName,
  getModelBrandId,
  getModelFeedBrandNames,
  getModelFeedModelNames,
  getModelImage,
  getModelThumb,
  getModelTitle,
  getModelColorImage,
} from '@/js/utils/modelFields';
import { IS_MODEL_PREFIX_URL } from '@/const';
export async function getStaticPaths() {
  if (isRouteDisabled('/models/')) return [];
  const { models } = modelsData;
  return models.filter(isModelVisible).map((model) => {
    return {
      params: { slug: setPrefixModelUrl(model, IS_MODEL_PREFIX_URL) },
      props: { model },
    };
  });
}


import settings from '@/data/site/settings.json';
const { legal_city_where } = settings;
import { getRandomInt } from '@/js/utils/numbers.format';
import { breadcrumb } from './index.astro';
const { model } = Astro.props;
const modelTitle = getModelTitle(model);
const brandDisplayName = getModelBrandDisplayName(model);
const brandId = getModelBrandId(model);

// Данные для сохранения "последней просмотренной модели" в Alpine store
const lastViewedModelForStore = {
  idNormalized: normalizeModelId(model.id),
  markId: brandId,
};
const lastViewedModelJSON = JSON.stringify(lastViewedModelForStore);

import { getSafeCollection } from '@/js/utils/safeContent';
import { filterVisibleCars } from '@/js/utils/car';
const rawCars = await getSafeCollection("cars");
const cars = rawCars && rawCars.length ? filterVisibleCars(rawCars)
  .filter((car) => {
    const carMark = car.data.mark_id.toLowerCase();
    const carFolder = normalizeModelId(car.data.folder_id);
    const modelId = normalizeModelId(model.id);
    const feedNames = getModelFeedModelNames(model).map((name: string) => normalizeModelId(name));
    const feedBrands = getModelFeedBrandNames(model).map((name: string) => String(name).toLowerCase());
    return (
      (carMark === brandId || feedBrands.includes(carMark)) &&
      (carFolder === modelId || feedNames.includes(carFolder))
    );
  })
: [];
import salonsData from '@/data/site/salons.json';
import type { ISalon } from '@/types/ISalon';
const salons = salonsData.filter((salon: ISalon) => !salon?.type || salon?.type.includes('index'));
const salonsPhone = salons.map((salon: any) => salon.phone).filter(phone => phone).join(', ');

import {STATUS} from '@/const';
import type { TStatus } from '@/types/TStatus';

const status: TStatus = (model?.status && STATUS.includes(model.status as TStatus)) ? model.status : 'enable';

// Блоки контента модели из JSON (page.blocks)
const contentBlocks = getModelBlocks(model);
const getBlockImages = (block: any) =>
  Array.isArray(block?.content?.images) ? block.content.images : [];
const firstSectionImageUrl = contentBlocks
  .flatMap(getBlockImages)
  .find((image: any) => image?.url)
  ?.url;

const modelBreadcrumb = [breadcrumb, { name: modelTitle, href: Astro.url.pathname }];

// Контекст страницы — runtime-данные для блоков (model/cars/complectations берут отсюда).
const context = {
  model,
  status,
  breadcrumb: modelBreadcrumb,
  cars,
  brandDisplayName,
  modelTitle,
  legal_city_where,
  carsTitle: `Автомобили ${brandDisplayName}&nbsp;${modelTitle} в наличии в ${legal_city_where}`,
};

// Сборка страницы модели из блоков. JSON-блоки (contentBlocks) встраиваются между
// структурными; порядок и условия — ответственность шаблона страницы.
// model / model-complectations / cars-grid само-гейтятся внутри BlockRenderer по context.
const blocks = [
  { type: 'page-h1', props: { h1: `Автомобиль ${brandDisplayName} ${modelTitle} в ${legal_city_where}`, classes: 'sr-only' } },
  { type: 'model' },
  ...contentBlocks,
  { type: 'model-complectations' },
  { type: 'seo-text', props: { mdx: seoname, sectionPaddingBlock: true } },
  ...((status === 'enable' || status === 'show')
    ? [{ type: 'feedback-form', props: {
        title: 'Записаться на тест-драйв',
        imageUrl: firstSectionImageUrl || ((model.colors && model.colors.length > 0)
          ? getModelColorImage(model.colors[getRandomInt(0, model.colors.length)])
          : getModelThumb(model)),
      } }]
    : []),
  ...(status === 'preorder'
    ? [{ type: 'feedback-form', props: { title: `Забронировать новый ${brandDisplayName} ${model.name}` } }]
    : []),
  { type: 'cars-grid' },
];
---
<Layout
  title={`${brandDisplayName} ${modelTitle} – фото, цены, комплектации и характеристики ${brandDisplayName} ${modelTitle} в ${legal_city_where}`}
  description={`${brandDisplayName} ${modelTitle} купить в ${legal_city_where}. Кредит, скидки на все автомобили от розничной цены. Гарантия. Звонить по тел.: ${salonsPhone}`}
  image={getModelImage(model)}
  brand={brandId}
  breadcrumb={[breadcrumb, { name: modelTitle, href: Astro.url.pathname }]}
>
  <div x-init={`$store.lastViewedModel.setModel(${lastViewedModelJSON})`} class="hidden"></div>
  <BlockRenderer blocks={blocks} context={context} />
</Layout>
