---
import { isRouteDisabled, SITE_NOT_FOUND_PATH } from '@/js/utils/siteRoutes';
if (isRouteDisabled('/models/')) {
	return Astro.rewrite(SITE_NOT_FOUND_PATH);
}
import settings from '@/data/site/settings.json';
const { brand, legal_city_where } = settings;
import Layout from '@/layouts/Layout.astro';
import ModelList from '@/blocks/model/ModelList.astro';
import Breadcrumbs from '@/ui/breadcrumbs/Breadcrumbs.astro';
export const breadcrumb = { name: `Модели`, href: "/models/" };
import SeoText from '@/blocks/seo-text/SeoText.astro';
import PageH1 from '@/ui/page-h1/PageH1.astro';
---
<Layout 
	title={`Модельный ряд ${brand} – Официальный дилер ${brand} в ${legal_city_where}`} 
	description={`Информация о моделях ${brand} 2024-2025 на сайте официального дилера в ${legal_city_where}: обзор, цены, комплектации, технические характеристики.`}
	breadcrumb={[breadcrumb]}
>
	<section class="content">
		<div class="container">
			<Breadcrumbs breadcrumb={[breadcrumb]} />
			<PageH1 h1={`Модели ${brand}`} />
		</div>
	</section>
	<SeoText mdx="models" />
	<ModelList title="" classes="pt-0! pb-10" />
</Layout>