---
import settings from '@/data/settings.json';
import Layout from '@/layouts/Layout.astro';
import ModelList from '@/components/Model/ModelList.astro';
import Breadcrumbs from '@/components/Breadcrumbs/Breadcrumbs.astro';
import SeoText from '@/components/Seo/Index.astro';
import PageH1 from '@/components/PageH1/Index.astro';

export const breadcrumb = { name: `Модели`, href: "/models/" };

const { brand, legal_city_where } = settings;
const isDisabled = settings.disabled_routes?.some(r => breadcrumb.href.startsWith(r));
if (import.meta.env.PROD && isDisabled) {
  return new Response();
}
---
<Layout 
	title={`Модельный ряд ${brand} – Официальный дилер ${brand} в ${legal_city_where}`} 
	description={`Информация о моделях ${brand} 2024-2025 на сайте официального дилера в ${legal_city_where}: обзор, цены, комплектации, технические характеристики.`}
>
	<section class="content">
		<div class="container">
			<Breadcrumbs breadcrumb={[breadcrumb]} />
			<PageH1 h1={`Модели ${brand}`} />
		</div>
	</section>
	<SeoText mdx="models" />
	<ModelList title="" classes="pt-0! pb-10" />
</Layout>