---
import Layout from '@/layouts/Layout.astro';
import { ChatWidget } from '@/components/React/ChatWidget/ChatWidget-v2';
import { USPSection } from '@/components/React/USPSection';
import Banner from '@/components/Banner/Banner.astro'
import siteSettings from '@/data/site/settings.json';
import modelsData from '@/data/site/models.json';
import { getModelBrandDisplayName, getModelThumb, getModelTitle } from '@/js/utils/modelFields';
import { isModelVisible } from '@/js/utils/modelVisibility';
import salonsData from '@/data/site/salons.json';
import type { ISalon } from '@/types/ISalon';
const salons = salonsData.filter((salon: ISalon) => !salon?.type || salon?.type.includes('index'));
const salonsPhone = salons.map((salon: any) => salon.phone).filter(phone => phone).join(', ');
// import.meta.glob — Vite-нативный optional import (не падает если файла нет)
const chatFiles = import.meta.glob('/src/data/site/chat-landing.json', { eager: true });
const chatConfig: any = (Object.values(chatFiles)[0] as any)?.default || { settings: {}, questions: [] };

const { models } = modelsData;
const visibleModels = models.filter(isModelVisible);
const banners = [
    {
        "id": 1,
        "show": true,
        "type": "video",
        "view": "popup-link",
        "video": {
            "desktop": "https://alexsab.ru/video/jetour-dashing-compress.mp4"
        },
        "image": {
            "desktop": "https://cdn.alexsab.ru/models/default-model-bg.webp"
        },
        "title": "Заголовок баннера до 31.08.2024",
        "descr": "Подзаголовок баннера может быть длиннее или короче за 1 234 567 ₽",
        "btn": "Онлайн запись",
        "btnUrl": "#common-modal",
        "dataTitle": "Онлайн запись",
        "dataFormName": "Онлайн запись. Баннер",
        "badge": {
            "autoname": "Jetour Dashing",
            "title": "Ежегодная национальная премия",
            "descr": "Победитель номинации <br>«новинка в&nbsp;массовом сегменте»",
            "image": "https://jetour-alpha.ru/img/badge-4x4-2024.png"
        },
        "autoplay": 6000
    },
];
// Fallback: берём brand/dealer/legalCityWhere из settings.json если не заданы в chat-landing.json
const chatSettings = chatConfig.settings || {};
const mergedSettings = {
    ...chatSettings,
    brand: chatSettings.brand || siteSettings.brand || '',
    dealer: chatSettings.dealer || siteSettings.site_name || '',
    legalCityWhere: chatSettings.legalCityWhere || siteSettings.legal_city_where || '',
};

// Обогащаем вопросы данными из models.json
const config = {
    ...chatConfig,
    settings: mergedSettings,
    // Справочник моделей: id — ключ выбора, name — подпись для заявки
    models: visibleModels.map((m: any) => ({
        id: m.id,
        name: `${getModelBrandDisplayName(m)} ${getModelTitle(m)}`,
        colors: (m.colors || []).map((c: any) => ({ id: c.id, name: c.name })),
    })),
    questions: chatConfig.questions.map(q => {
        if (q.id !== 'model') return q;
        // Пустой answerOptions — все видимые модели; иначе фильтр по id или legacy name
        const sourceModels =
            q.answerOptions.length === 0
                ? visibleModels
                : q.answerOptions
                      .map((a: any) => (typeof a === 'string' ? a : a?.value ?? a))
                      .map((key: string) =>
                          visibleModels.find(
                              (m: any) => m.id === key || m.name === key,
                          ),
                      )
                      .filter(Boolean);
        const newOptions = sourceModels.map((model: any) => ({
            label: `${getModelBrandDisplayName(model)} ${getModelTitle(model)}`,
            value: model.id,
            description: model.slogan,
            image: getModelThumb(model),
        }));
        return { ...q, answerOptions: newOptions };
    }),
};
---

<Layout
    h1=`Купить ${mergedSettings.brand} у официального дилера ${siteSettings.site_name}`
    title=`Купить ${mergedSettings.brand} у официального дилера ${siteSettings.site_name}`
    description=`Забронируйте свой автомобиль прямо сейчас у официального дилера ${mergedSettings.brand} в ${mergedSettings.legalCityWhere}! ☎️ ${salonsPhone}`
    footerVersion="3"
    showHeaderMenu={false}
    showFooterLinks={false}
    logoNoLink={true}
>

<!-- <Banner banners={banners} /> -->

<section class="pb-14!">
    <div class="container">
        <USPSection client:visible usps={chatConfig.usps} />
    </div>
    <ChatWidget client:visible={{rootMargin: "-210px"}} config={config} />
</section>


</Layout>
