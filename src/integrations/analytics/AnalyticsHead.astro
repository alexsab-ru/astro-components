---
import scripts_json from '@/data/site/scripts.json';
import settings_json from '@/data/site/settings.json';
const { site_name, legal_city, connectforms_link, grecaptcha_open, grecaptcha_action } = settings_json;
const dealer_params = JSON.stringify({
    domain_region: site_name,
    region: legal_city,
    ...(connectforms_link && { connectforms_link }),
    ...(grecaptcha_open && { grecaptcha_open }),
    ...(grecaptcha_action && { grecaptcha_action })
});
import { cleanScriptsData } from '@/integrations/analytics/providers/clean-scripts-data';
import GTM from '@/integrations/analytics/providers/GoogleTagManager.astro';
import METRIKA_DEV from '@/integrations/analytics/providers/YandexMetrikaDevelopment.astro';
import METRIKA from '@/integrations/analytics/providers/YandexMetrika.astro';
import GA4 from '@/integrations/analytics/providers/GoogleAnalytics.astro';
import RE from '@/integrations/analytics/providers/ReAnalytics.astro';
import VK_RTRG from '@/integrations/analytics/providers/VkRetargetingAnalytics.astro';
import TOP_MAIL_RU from '@/integrations/analytics/providers/TopMailRuAnalytics.astro';
import CALLTOUCH from '@/integrations/analytics/providers/CalltouchAnalytics.astro';
import KONGET from '@/integrations/analytics/providers/KongetAnalytics.astro';
import STREAMWOOD from '@/integrations/analytics/providers/StreamwoodAnalytics.astro';
import SMARTPOINT from '@/integrations/analytics/providers/SmartpointAnalytics.astro';
import WIDGETS from '@/integrations/analytics/providers/WidgetsScripts.astro';
import LoadAnalyticsScripts from '@/integrations/analytics/providers/LoadAnalyticsScripts.astro';
import DWELL from '@/integrations/analytics/providers/DwellAnalytics.astro';

const cleanedScripts = cleanScriptsData(scripts_json);
---
<script id="scripts_json" type="application/ld+json" set:html={cleanedScripts}/>
<script id="settings_json" type="application/ld+json" set:html={dealer_params}/>
<GTM />
<METRIKA_DEV />
<METRIKA />
<GA4 />
<RE />
<VK_RTRG />
<TOP_MAIL_RU />
<CALLTOUCH />
<KONGET />
<STREAMWOOD />
<SMARTPOINT />
<WIDGETS />
<DWELL />
<LoadAnalyticsScripts />
