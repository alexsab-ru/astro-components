---
import scripts_json from '@/data/site/scripts.json';
import settings_json from '@/data/site/settings.json';
const { site_name, legal_city, connectforms_link, grecaptcha_open, grecaptcha_action } = settings_json;
const dealer_params = JSON.stringify({
    domain_region: site_name,
    region: legal_city,
    ...(connectforms_link && { connectforms_link }),
    ...(grecaptcha_open && { grecaptcha_open }),
    ...(grecaptcha_action && { grecaptcha_action })
});
import { cleanScriptsData } from '@/integrations/scripts/providers/clean-scripts-data';
import GTM from '@/integrations/scripts/providers/GoogleTagManager.astro';
import METRIKA_DEV from '@/integrations/scripts/providers/YandexMetrikaDevelopment.astro';
import METRIKA from '@/integrations/scripts/providers/YandexMetrika.astro';
import GA4 from '@/integrations/scripts/providers/GoogleAnalytics.astro';
import RE from '@/integrations/scripts/providers/ReCaptcha.astro';
import VK_RTRG from '@/integrations/scripts/providers/VkRetargetingPixel.astro';
import TOP_MAIL_RU from '@/integrations/scripts/providers/TopMailRuPixel.astro';
import CALLTOUCH from '@/integrations/scripts/providers/Calltouch.astro';
import KONGET from '@/integrations/scripts/providers/Konget.astro';
import STREAMWOOD from '@/integrations/scripts/providers/Streamwood.astro';
import SMARTPOINT from '@/integrations/scripts/providers/Smartpoint.astro';
import WIDGETS from '@/integrations/scripts/providers/WidgetsScripts.astro';
import LoadAnalyticsScripts from '@/integrations/scripts/providers/LoadScripts.astro';
import DWELL from '@/integrations/scripts/providers/DwellBeacon.astro';

const cleanedScripts = cleanScriptsData(scripts_json);
---
<script id="scripts_json" type="application/ld+json" set:html={cleanedScripts}/>
<script id="settings_json" type="application/ld+json" set:html={dealer_params}/>
<GTM />
<METRIKA_DEV />
<METRIKA />
<GA4 />
<RE />
<VK_RTRG />
<TOP_MAIL_RU />
<CALLTOUCH />
<KONGET />
<STREAMWOOD />
<SMARTPOINT />
<WIDGETS />
<DWELL />
<LoadAnalyticsScripts />
