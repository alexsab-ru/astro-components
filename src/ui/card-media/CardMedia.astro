---
type TImage = {
  imageUrl: string;
  thumbUrl?: string;
}

interface Props {
  imgPlacement?: string;
  images?: TImage[];
  imageAspectRatio?: 'auto' | '4/3' | '16/9' | '3/2' | '1/1';
  imageFit?: 'cover' | 'contain';
  lightboxDescription?: string;
}

const {
  imgPlacement = 'left',
  images = [],
  imageAspectRatio = 'auto',
  imageFit = 'contain',
  lightboxDescription,

} = Astro.props;
const aspectRatioClasses = {
  auto: '',
  '4/3': 'aspect-4/3',
  '16/9': 'aspect-video',
  '3/2': 'aspect-3/2',
  '1/1': 'aspect-square',
};
const hasFixedAspectRatio = imageAspectRatio !== 'auto';
const imageClasses = hasFixedAspectRatio
  ? `w-full h-full ${imageFit === 'cover' ? 'object-cover' : 'object-contain'} object-center`
  : 'w-full h-auto object-contain object-center';
---

<article class=`flex flex-col ${imgPlacement === 'right' ? 'lg:flex-row-reverse' : 'lg:flex-row'} bg-zinc-50 rounded-2xl overflow-hidden`>
  {images.length > 0 && (
    <div class={`swiper model-gallery-slider w-full lg:w-1/2 bg-zinc-100 ${aspectRatioClasses[imageAspectRatio]}`}>
      <div class={`swiper-wrapper ${hasFixedAspectRatio ? 'h-full' : ''}`}>
      {images.map(img => (
          <div class={hasFixedAspectRatio ? 'swiper-slide h-full!' : 'swiper-slide'}>
            {img.thumbUrl ? (
              <a href={img.imageUrl} class={`glightbox cursor-zoom-in select-none ${hasFixedAspectRatio ? 'block h-full' : ''}`} data-gallery={images[0].imageUrl} data-description={lightboxDescription}>
                <img src={img.thumbUrl} class={imageClasses} loading="lazy" />
              </a>
            ) : (
              <img src={img.imageUrl} class={imageClasses} loading="lazy" />
            )}
          </div>
        )
      )}
      </div>
      <div class="swiper-pagination simple-slider-pagination bottom-0"></div>
      <div class="swiper-button-prev model-gallery-slider-button-prev hidden! sm:flex! bg-white/80!"></div>
      <div class="swiper-button-next model-gallery-slider-button-next hidden! sm:flex! bg-white/80!"></div>
    </div>
  )}
  <div><slot name="card-image" /></div>
  <div class="flex shrink-0 lg:w-1/2 flex-col justify-center gap-6 lg:gap-12 px-6 py-12 lg:px-12">
    <slot name="card-content" />
  </div>
</article>
