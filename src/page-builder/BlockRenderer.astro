---
// Реестр блоков page-builder: type (из page.blocks JSON или из роута) -> компонент.
// Каждый case адаптирует блок к пропсам компонента ЕДИНООБРАЗНО:
//   c = данные блока (JSON content + route props, props важнее);
//   context = данные страницы (model, cars, ...) для блоков, которым нужен runtime-контекст.
// Добавить блок = импорт + ветка в switch.
import type { TBlock } from './types';
import RichContentBlock from '@/blocks/rich-content/RichContentBlock.astro';
import Faq from '@/blocks/faq/Faq.astro';
import Model from '@/blocks/model/Model.astro';
import PageH1 from '@/ui/page-h1/PageH1.astro';
import SeoText from '@/blocks/seo-text/SeoText.astro';
import ModelComplectations from '@/blocks/model/ModelComplectations.astro';
import FeedbackForm from '@/blocks/forms/feedback-form/FeedbackForm.astro';
import Callback from '@/blocks/forms/callback/Callback.astro';
import CarsGrid from '@/blocks/cars-grid/CarsGrid.astro';

interface Props {
	blocks?: TBlock[];
	context?: Record<string, any>;
}
const { blocks = [], context = {} } = Astro.props;

// Данные блока: JSON content + route props (props важнее). any — блоки собираются динамически.
const data = (block: TBlock): any => ({ ...(block?.content ?? {}), ...(block?.props ?? {}) });
---
{
	blocks.map((block) => {
		const c = data(block);
		switch (block?.type) {
			case 'page-h1':
				return <PageH1 h1={c.h1 ?? c.title ?? ''} classes={c.classes ?? c.class ?? ''} />;
			case 'model':
				return context.model
					? <Model model={context.model} status={context.status} breadcrumb={context.breadcrumb} />
					: null;
			case 'rich-content':
				return <RichContentBlock section={block} />;
			case 'faq':
				return (
					<Faq
						items={c.items ?? []}
						title={c.title}
						id={block.id}
						class={`sm:py-20 py-10 font-light model-section odd:bg-gray-100 ${block.sectionClass ?? c.sectionClass ?? ''}`}
						withSchema={Boolean(c.withSchema ?? c.schema ?? false)}
					/>
				);
			case 'model-complectations':
				return context.model?.complectations?.length
					? <ModelComplectations model={context.model} brand={context.brandDisplayName} title={c.title ?? `Подобрать комплектацию ${context.brandDisplayName ?? ''} ${context.modelTitle ?? ''}`} />
					: null;
			case 'seo-text':
				return <SeoText mdx={c.mdx} text={c.text} noPadding={c.noPadding} sectionPaddingBlock={c.sectionPaddingBlock} />;
			case 'feedback-form':
				return (
					<section>
						<div class="section-grid">
							<FeedbackForm title={c.title} subtitle={c.subtitle} imageUrl={c.imageUrl ?? context.feedbackImageUrl ?? ''} dataFormName={c.dataFormName} showModelSelect={c.showModelSelect} />
						</div>
					</section>
				);
			case 'callback':
				return <Callback bgUrl={c.bgUrl} bgImage={c.bgImage} bgPosition={c.bgPosition} title={c.title} subtitle={c.subtitle} formName={c.formName} btn={c.btn} showComment={c.showComment} commentPlaceholder={c.commentPlaceholder} />;
			case 'cars-grid':
				return context.cars?.length
					? <CarsGrid cars={context.cars} title={c.title ?? context.carsTitle} />
					: null;
			default:
				return null;
		}
	})
}
