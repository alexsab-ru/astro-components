---
import type { TBreadcrumb } from '@/ui/breadcrumbs/types';
interface Props {
	title?: string;
	h1?: string;
	description?: string;
	image?: string;
	keywords?: string;
	brand?: string;
	breadcrumb?: TBreadcrumb[];
	footerVersion?: string | number;
	showHeaderMenu?: boolean;
	showFooterLinks?: boolean;
	logoNoLink?: boolean;
}
let {title, h1, description, image, keywords, brand = null, breadcrumb, footerVersion = '2', showHeaderMenu = true, showFooterLinks = true, logoNoLink = false} = Astro.props;

import settings from '@/data/site/settings.json';
const { site_name, site_description, is_header_transparent } = settings;

import Head from '@/integrations/seo/DocumentHead.astro';
import ScriptHead from '@/integrations/scripts/ScriptsHead.astro';
import ScriptBodyBegin from '@/integrations/scripts/ScriptsBodyBegin.astro';
import ScriptBodyEnd from '@/integrations/scripts/ScriptsBodyEnd.astro';
import Header from '@/site-shell/header/Header.astro';
import Modals from '@/site-shell/modals/Modals.astro';
import UpBtn from '@/ui/up-btn/UpBtn.astro';
import Cookie from '@/site-shell/cookie/Cookie.astro';
import seo from '@/data/site/seo.json';
import StripEmptyQuery from '@/site-shell/strip-empty-query/StripEmptyQuery.astro';
import Tooltip from '@/ui/tooltip/Tooltip.astro';
import SchemaOrg from '@/integrations/schema-org/SchemaOrg.astro';

import FooterV1 from '@/site-shell/footer/FooterV1.astro';
import FooterV2 from '@/site-shell/footer/FooterV2.astro';
import FooterV3 from '@/site-shell/footer/FooterV3.astro';
const FOOTER_MAP = {
	'1': FooterV1,
	'2': FooterV2,
	'3': FooterV3, // Резерв для V3
};
const Footer = FOOTER_MAP[String(footerVersion)] || FooterV2;

const currentPath = Astro.url.pathname;
if (seo[currentPath]) {
	const pageSeo = seo[currentPath];

	if (pageSeo.title && pageSeo.title.trim()) {
		title = pageSeo.title;
	}

	if (pageSeo.description && pageSeo.description.trim()) {
		description = pageSeo.description;
	}

	if (pageSeo.keywords && pageSeo.keywords.trim()) {
		keywords = pageSeo.keywords;
	}

	if (pageSeo.h1 && pageSeo.h1.trim()) {
		h1 = pageSeo.h1;
	}

	if (pageSeo.image && pageSeo.image.trim()) {
		image = pageSeo.image;
	}
}
import '../scss/app.css';

const bodyClasses = currentPath != '/' && is_header_transparent ? 'xs:pt-[52px] pt-[60px] md:pt-[80px] lg:pt-[130px]' : '';
---

<!doctype html>
<html lang="ru" {
	...brand ? {
		'data-brand': brand, 
		'x-data': '{selectBrand: null}', 
		"x-init" : `$store.salonsStore.filterPageData(${JSON.stringify(brand)}); $watch('selectBrand', value => $store.salonsStore.filterPageData(selectBrand))`,
		"@brand-updated.window" : "selectBrand = $event.detail.brand"
	} : 
		{}
	}>
	<head>
		<StripEmptyQuery />
		<Head title={title || h1 || site_name} description={description ?? site_description} image={image} keywords={keywords} />
		<ScriptHead />
		<SchemaOrg breadcrumbs={breadcrumb} />
	</head>
	<body class={`antialiased flex flex-col min-w-80 min-h-screen overflow-x-hidden text-black ${bodyClasses}`} x-data="complectation">
		<ScriptBodyBegin />
		<Header brand={brand} showMenu={showHeaderMenu} logoNoLink={logoNoLink} />
		<main class="grow relative">
			<slot />
		</main>
		<Footer showSiteLinks={showFooterLinks} logoNoLink={logoNoLink} />
		<Modals />
		<UpBtn />
		<Cookie />
		<ScriptBodyEnd />
		<Tooltip />
	</body>
</html>
